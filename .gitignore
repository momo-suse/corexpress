# ── PHP dependencies (generated by: composer install) ─────────────────────────
packages/app/vendor/

# ── Runtime config (generated by the web installer) ───────────────────────────
packages/app/config.php
packages/installer/config.php

# ── PHP logs ───────────────────────────────────────────────────────────────────
*.php.log

# ── Node.js dependencies (generated by: npm install) ──────────────────────────
node_modules/
**/node_modules/

# ── Root package-lock (root package.json has no real deps — lock is meaningless)
/package-lock.json

# ── Vite / React build outputs (generated by: npm run build) ──────────────────
# packages/web/index.html is the SOURCE entry point — DO NOT ignore it
# packages/app/public/index.html is the BUILD output — ignore it
packages/app/public/index.html
packages/app/public/assets/
packages/web/.vite/

# ── User-uploaded images (generated at runtime) ────────────────────────────────
# Keep .htaccess (blocks PHP execution in the upload dir — security requirement)
packages/app/public/img/*
!packages/app/public/img/.htaccess

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
.env.*

# ── Logs ───────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Test artifacts ─────────────────────────────────────────────────────────────
coverage/
.phpunit.result.cache

# ── OS files ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor files ───────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── TypeScript ─────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Claude AI (project memory — local only, not for collaborators) ─────────────
CLAUDE.md
.claude/
