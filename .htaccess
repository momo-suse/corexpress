# Corexpress — Root dispatcher for Hostinger shared hosting
# Routes requests to the correct package (app or installer)

Options -Indexes

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
</IfModule>

RewriteEngine On

# Static assets (React build output + uploaded images)
RewriteRule ^(assets|img)(/.*)$ packages/app/public/$1$2 [L]

# Installer static files (images, CSS) — must come BEFORE the PHP rewrite
RewriteRule ^setup/(docs/.+)$ packages/installer/$1 [L]

# Web installer (/setup and /setup?...)
RewriteCond %{REQUEST_URI} ^/setup(/)?$
RewriteRule ^setup(/)?$ packages/installer/index.php [L,QSA]

# Everything else → Slim 4 front-controller
RewriteRule ^ packages/app/public/index.php [QSA,L]
