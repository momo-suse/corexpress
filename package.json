{
  "name": "corexpress",
  "version": "0.1.0",
  "private": true,
  "description": "Corexpress — personal blog platform for Hostinger shared hosting",
  "scripts": {
    "podman:up": "podman compose -f compose.dev.yml up -d",
    "podman:down": "podman compose -f compose.dev.yml down -v",
    "podman:logs": "podman compose -f compose.dev.yml logs -f",
    "podman:rebuild": "podman compose -f compose.dev.yml build --no-cache",
    "docker:up": "docker compose -f compose.dev.yml up -d",
    "docker:down": "docker compose -f compose.dev.yml down -v",
    "docker:logs": "docker compose -f compose.dev.yml logs -f",
    "docker:rebuild": "docker compose -f compose.dev.yml build --no-cache",
    "frontend:dev": "pnpm --filter @corexpress/web run dev",
    "frontend:build": "pnpm --filter @corexpress/web run build",
    "frontend:install": "pnpm install && pnpm --filter @corexpress/web run build",
    "test:web": "pnpm --filter @corexpress/web run test",
    "test:php": "docker exec corexpress-hosting bash -c 'cd /var/www/html/packages/app && vendor/bin/phpunit --no-coverage'",
    "test:php:coverage": "docker exec corexpress-hosting bash -c 'cd /var/www/html/packages/app && vendor/bin/phpunit'",
    "test:php:podman": "podman exec corexpress-hosting bash -c 'cd /var/www/html/packages/app && vendor/bin/phpunit --no-coverage'"
  },
  "workspaces": [
    "packages/web"
  ],
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.4.0"
  },
  "dependencies": {
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^16.5.6"
  }
}
