{
  "name": "corexpress",
  "version": "0.1.0",
  "private": true,
  "description": "Corexpress — personal blog platform for Hostinger shared hosting",
  "scripts": {
    "podman:up": "podman compose -f compose.dev.yml up -d",
    "podman:down": "podman compose -f compose.dev.yml down -v",
    "podman:logs": "podman compose -f compose.dev.yml logs -f",
    "podman:rebuild": "podman compose -f compose.dev.yml build --no-cache",
    "frontend:build": "npm run build --workspace=packages/web",
    "frontend:install": "npm install && npm run build --workspace=packages/web",
    "test:web": "npm run test --workspace=packages/web"
  },
  "workspaces": [
    "packages/web"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "i18next": "^25.8.14",
    "i18next-browser-languagedetector": "^8.2.1",
    "react-i18next": "^16.5.6"
  }
}
